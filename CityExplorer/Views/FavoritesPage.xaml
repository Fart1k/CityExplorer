<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CityExplorer.Views.FavoritesPage"
             Title="Favorites">

    <CollectionView x:Name="FavoritesCollection" ItemsSource="{Binding Favorites}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame Margin="10" BackgroundColor="#1E1E1E">

                    <VerticalStackLayout>

                        <Image 
                            Source="{Binding Image}"
                            HeightRequest="150"
                            Aspect="AspectFill"/>

                        <Label 
                            Text="{Binding Name}"
                            FontSize="20"
                            FontAttributes="Bold"/>

                        <Label 
                            Text="{Binding Description}"/>

                        <Button
                            Text="Remove"
                            Clicked="RemoveButton_Clicked"/>

                    </VerticalStackLayout>
                    
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
    
    
</ContentPage>