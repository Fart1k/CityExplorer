<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CityExplorer.Views.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Spacing="10" Padding="20">

        <Label Text="Language" FontSize="24"/>

        <Button Text="English" Command="{Binding SetEnglishCommand}" />
        <Button Text="Eesti" Command="{Binding SetEstonianCommand}" />
        <Button Text="Русский" Command="{Binding SetRussianCommand}" />

    </VerticalStackLayout>

</ContentPage>